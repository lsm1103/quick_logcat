{
  "name": "quick-logcat",
  "version": "0.1.0",
  "description": "浏览器里看 Android logcat 的轻量工具，替代 Android Studio 自带的 Logcat 面板——不用为了看日志打开整个 IDE，省内存省磁盘。",
  "type": "module",
  "license": "MIT",
  "bin": {
    "quick-logcat": "./bin/cli.js"
  },
  "files": [
    "bin",
    "server/index.js",
    "server/adb.js",
    "client/dist",
    "install-adb.sh",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node bin/cli.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "ws": "^8.18.0"
  }
}
